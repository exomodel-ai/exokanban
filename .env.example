# ── LLM ───────────────────────────────────────────────────────────────────────
# Format: provider:model
# Options:
#   google_genai:gemini-2.5-flash-lite   → pip install exomodel[google]
#   google_genai:gemini-2.5-flash
#   anthropic:claude-sonnet-4-6          → pip install exomodel[anthropic]
#   openai:gpt-4o                        → pip install exomodel[openai]
MY_LLM_MODEL=google_genai:gemini-2.5-flash-lite

# Embedding model (defaults to provider's recommended model if not set)
# MY_EMB_MODEL=google_genai:gemini-embedding-2

# ── API Keys ──────────────────────────────────────────────────────────────────
# Set only the key for the provider chosen above.
GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Interaction mode ──────────────────────────────────────────────────────────
# cli      → terminal interativo (padrão)
# telegram → bot Telegram
INTERACTION_MODE=cli

# ── Telegram (obrigatório se INTERACTION_MODE=telegram) ───────────────────────
# Token gerado pelo @BotFather no Telegram.
# TELEGRAM_TOKEN=

# IDs numéricos dos usuários autorizados, separados por vírgula.
# Deixe em branco para bot público (qualquer usuário pode interagir).
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# Exibe os cards do /board como botões inline clicáveis (apenas Telegram).
# true → cada card vira um botão; clicar abre o card diretamente.
# false → exibição em texto puro (padrão).
# BOARD_CARD_BUTTONS=true

# ── Banco de dados ────────────────────────────────────────────────────────────
# SQLite local por padrão. Troque por postgresql+psycopg2://... para produção.
# DATABASE_URL=sqlite:///exokanban.db

# ── MCP Server (python mcp_server.py) ─────────────────────────────────────────
# Bearer token required in the Authorization header of every MCP request.
# Leave blank to disable auth (not recommended in production).
MCP_AUTH_TOKEN=

# Host and port the MCP server listens on.
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# Board name the MCP server connects to (must match the seed board name).
# MCP_BOARD_NAME=Kanban to-do
